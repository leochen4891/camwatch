    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Frames/sec decoded (main) and consumed by the detector loop (yolo). A persistent gap = frames dropped at the reader-to-consumer queue.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "group": "A",
              "mode": "none"
            }
          },
          "min": 0,
          "unit": "fps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 7,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (camera, stream) (rate(camwatch_engine_frames_total{camera=~\"$camera\"}[$__rate_interval]))",
          "legendFormat": "{{camera}}/{{stream}}",
          "refId": "A"
        }
      ],
      "title": "Capture frame rate",
      "type": "timeseries"
    },
