      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "camwatch_engine_capture_paused{camera=~\"$camera\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
